+class _SingleBatchIterator:
+    """Yield exactly one already-materialized batch."""
+
+    def __init__(self, batch):
+        self._batch = batch
+        self._consumed = False
+
+    def __iter__(self):
+        return self
+
+    def __next__(self):
+        if self._consumed:
+            raise StopIteration
+        self._consumed = True
+        return self._batch

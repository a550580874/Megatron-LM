+def _batch_l2_norm(batch):
+    total = 0.0
+    for value in batch.values():
+        if torch.is_tensor(value) and value is not None:
+            tensor = value.detach().to(dtype=torch.float64)
+            total += torch.sum(tensor * tensor).item()
+    return total ** 0.5
+
